# ──────────────────────────────────────────────
# Zoom-Out — Environment Variables
# Copy to .env and customize for your environment
# ──────────────────────────────────────────────

# ──── PostgreSQL ────
DATABASE_URL=postgresql://zoom:zoom_secret@localhost:5432/zoomout
POSTGRES_USER=zoom
POSTGRES_PASSWORD=zoom_secret
POSTGRES_DB=zoomout

# ──── LiveKit ────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret

# ──── MinIO (S3-compatible Object Storage) ────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RECORDINGS=recordings
MINIO_USE_SSL=false

# ──── Faster-Whisper (Transcription) ────
WHISPER_API_URL=http://localhost:9090
WHISPER_MODEL=large-v3-turbo

# ──── API Server ────
API_PORT=3001
JWT_SECRET=dev-jwt-secret-change-in-production-minimum-32-chars

# ──── Frontend (Vite — must be prefixed with VITE_) ────
# VITE_API_URL=  # Vacío = auto-detect vía Vite proxy. Solo setear si API está en otro host
# VITE_LIVEKIT_URL=  # Vacío = auto-detect en Room.tsx (localhost→ws:7880, https→wss:7443)
VITE_WEB_URL=http://localhost:5173

# ──── Backend Config ────
WEB_URL=http://localhost:5173
